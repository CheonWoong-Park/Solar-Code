{
  "name": "solar-code",
  "version": "0.1.0",
  "description": "Solar Code — Solar-native terminal coding agent",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "solar": "./dist/index.js",
    "solar-code": "./dist/index.js",
    "oms": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@solar-code/core": "*",
    "@solar-code/engine": "*"
  },
  "optionalDependencies": {
    "@solar-code/claw-darwin-arm64": "*",
    "@solar-code/claw-darwin-x64": "*",
    "@solar-code/claw-linux-x64-gnu": "*",
    "@solar-code/claw-linux-arm64-gnu": "*",
    "@solar-code/claw-linux-x64-musl": "*",
    "@solar-code/claw-linux-arm64-musl": "*",
    "@solar-code/claw-win32-x64-msvc": "*",
    "@solar-code/claw-win32-arm64-msvc": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "solar",
    "upstage",
    "agent",
    "coding-agent",
    "korean-ai",
    "document-ai",
    "orchestration",
    "multi-agent",
    "claw-code",
    "ai",
    "llm",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ultraworkers/solar-code"
  },
  "homepage": "https://github.com/ultraworkers/solar-code#readme",
  "bugs": {
    "url": "https://github.com/ultraworkers/solar-code/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module"
}
